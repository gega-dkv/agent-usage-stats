# Agent Usage Stats Environment Variables

# Database location (default: ~/.config/agent-usage-stats/stats.db)
AGENT_USAGE_DB_PATH=

# Privacy mode: disabled | preview | full | raw
AGENT_USAGE_PRIVACY_MODE=disabled

# Custom session paths (comma-separated, supports glob patterns)
AGENT_USAGE_SESSION_PATHS=

# Enable telemetry (default: false)
AGENT_USAGE_TELEMETRY=false

# Currency display (default: USD)
AGENT_USAGE_CURRENCY=USD
